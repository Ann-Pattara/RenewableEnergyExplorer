<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RenewableEnergyBlazor</RootNamespace>
    <AssemblyName>RenewableEnergyBlazor</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Contracts\EnergyContracts.cs" Link="Contracts\EnergyContracts.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.0" />
    <!-- DevServer is only used when running BlazorApp standalone; not needed in hosted model -->
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
